rules_version = '2';

// Todo el acceso a datos de MiniAItura pasa por el servidor (Next.js API routes
// usando el Firebase Admin SDK, que IGNORA estas reglas). Por tanto, negamos
// cualquier acceso directo desde clientes (SDK web/móvil). Defensa en profundidad.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
