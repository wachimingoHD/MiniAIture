# =============================================================================
# MiniAItures - Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# In production, set these in Vercel project settings.

# -----------------------------------------------------------------------------
# Phase 1 - AI Providers (REQUIRED for image generation)
# -----------------------------------------------------------------------------

# Google Gemini API key. Mandatory for primary generation.
# Get it at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# fal.ai API key. Required for fallback generation and upscaling.
# Get it at: https://fal.ai/dashboard/keys
FAL_API_KEY=

# Auto-fallback behavior. Defaults to "true" if missing.
AUTO_FALLBACK_TO_FAL=true

# -----------------------------------------------------------------------------
# Phase 2 - Firebase (auth, Firestore, App Check)
# -----------------------------------------------------------------------------
# Get these from: https://console.firebase.google.com -> Project Settings

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase App Check (reCAPTCHA v3 site key)
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# Firebase Admin SDK (server-side credential, paste full JSON as a single line)
FIREBASE_ADMIN_CREDENTIALS=

# -----------------------------------------------------------------------------
# Phase 2 - Cloudflare R2 (Pro gallery image storage)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=miniaitures-gallery
R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Phase 2 - Stripe (subscriptions + affiliate commissions)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
